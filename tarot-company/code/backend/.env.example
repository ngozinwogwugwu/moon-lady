# Anthropic (Stage A + Stage B)
ANTHROPIC_API_KEY=

# OpenAI (Whisper transcription)
OPENAI_API_KEY=

# PostgreSQL — injected automatically by Railway Postgres plugin
DATABASE_URL=

# Ontology version — bump when Stage A or Stage B prompt changes
ONTOLOGY_VERSION_ID=prototype-v1

# Set to true to accept text input in place of audio (internal testing only)
DEV_TEXT_MODE=false

# Frontend URL for CORS — set to Railway/Vercel frontend URL
FRONTEND_URL=http://localhost:3000
